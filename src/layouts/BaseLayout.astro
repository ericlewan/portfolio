---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/styles.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  activePage?: 'work' | 'about' | 'writing';
  isHome?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://yaroslav.design/Images/SEO.png',
  activePage,
  isHome = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Prevent flash of wrong theme -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
      } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- SEO -->
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Yaroslav Kovalchuk" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <title>{title}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Crimson+Pro:ital,wght@0,400;0,600;1,400;1,600&family=Geist:wght@300;400;500&family=Geist+Mono:wght@300;400;500;700&display=swap" rel="stylesheet" />
  <slot name="head" />
</head>
<body>

  <Nav activePage={activePage} isHome={isHome} />

  <slot />

  <Footer />

  <!-- CUSTOM CURSOR -->
  <div class="cursor" id="cursor">
    <svg class="cursor-icon cursor-icon--eye" width="24" height="24" viewBox="0 0 24 24" fill="none">
      <path stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M3.275 15.296C2.425 14.192 2 13.639 2 12c0-1.64.425-2.191 1.275-3.296C4.972 6.374 7.818 4 12 4c4.182 0 7.028 2.374 8.725 4.704C21.575 9.81 22 10.361 22 12c0 1.64-.425 2.192-1.275 3.296C19.028 17.626 16.182 20 12 20c-4.182 0-7.028-2.374-8.725-4.704Z"/>
      <path stroke="white" stroke-width="1.5" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
    </svg>
    <svg class="cursor-icon cursor-icon--hourglass" width="20" height="20" viewBox="0 0 24 24" fill="none">
      <path stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M5 3h14M5 21h14M7 3v3l5 5 5-5V3M7 21v-3l5-5 5 5v3"/>
    </svg>
    <svg class="cursor-icon cursor-icon--arrow" width="20" height="20" viewBox="0 0 24 24" fill="white">
      <path d="M6.4 18L5 16.6L14.6 7H6V5h12v12h-2V8.4L6.4 18z"/>
    </svg>
    <span class="cursor-label">View case study</span>
  </div>

  <script>
    const cursor = document.getElementById('cursor')!;
    let mouseX = 0, mouseY = 0, rafId: number;

    document.addEventListener('mousemove', e => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (!rafId) {
        rafId = requestAnimationFrame(() => {
          cursor.style.transform = `translate3d(${mouseX}px, ${mouseY}px, 0) translate(-50%, -50%)`;
          rafId = 0;
        });
      }
    });
    document.addEventListener('mouseleave', () => cursor.classList.add('cursor--hidden'));
    document.addEventListener('mouseenter', () => cursor.classList.remove('cursor--hidden'));

    document.querySelectorAll('a, button').forEach(el => {
      el.addEventListener('mouseenter', () => cursor.classList.add('cursor--link'));
      el.addEventListener('mouseleave', () => cursor.classList.remove('cursor--link'));
    });

    // Hamburger menu
    const navToggle = document.getElementById('navToggle')!;
    navToggle.addEventListener('click', () => document.body.classList.toggle('nav-is-open'));
    document.querySelectorAll('.nav-links a').forEach(a => {
      a.addEventListener('click', () => document.body.classList.remove('nav-is-open'));
    });

    // Theme toggle
    const themeToggle = document.getElementById('themeToggle');

    function playToggleSound(toDark: boolean) {
      try {
        const ctx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const bufferSize = Math.floor(ctx.sampleRate * 0.055);
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (bufferSize * 0.12));
        }
        const source = ctx.createBufferSource();
        source.buffer = buffer;
        const filter = ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.value = toDark ? 700 : 1100;
        filter.Q.value = 0.8;
        const gain = ctx.createGain();
        gain.gain.value = 0.35;
        source.connect(filter);
        filter.connect(gain);
        gain.connect(ctx.destination);
        source.start();
      } catch(e) {}
    }

    let toggleCount = 0;
    let toggleResetTimer: ReturnType<typeof setTimeout>;

    function showEasterEgg() {
      if (document.querySelector('.egg-overlay')) return;

      const overlay = document.createElement('div');
      overlay.className = 'egg-overlay';

      const canvas = document.createElement('canvas');
      const msg = document.createElement('div');
      msg.className = 'egg-msg';
      msg.textContent = 'make up your mind.';

      overlay.appendChild(canvas);
      overlay.appendChild(msg);
      document.body.appendChild(overlay);

      // Matrix rain
      const c = canvas.getContext('2d')!;
      canvas.width  = window.innerWidth;
      canvas.height = window.innerHeight;
      const CHARS = 'LIGHTDARKLIGHTDARKLIGHTDARK01';
      const FS = 13;
      const cols = Math.floor(canvas.width / FS);
      const drops = Array.from({ length: cols }, () => -Math.floor(Math.random() * 20));
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

      const rainInterval = setInterval(() => {
        c.fillStyle = isDark ? 'rgba(18,20,26,0.08)' : 'rgba(255,255,255,0.08)';
        c.fillRect(0, 0, canvas.width, canvas.height);
        c.font = `${FS}px "Geist Mono",monospace`;
        c.textAlign = 'center';
        for (let i = 0; i < cols; i++) {
          const alpha = (0.08 + Math.random() * 0.35).toFixed(2);
          c.fillStyle = `rgba(255,85,0,${alpha})`;
          c.fillText(CHARS[Math.floor(Math.random() * CHARS.length)], i * FS + FS / 2, drops[i] * FS);
          if (drops[i] * FS > canvas.height && Math.random() > 0.97) drops[i] = 0;
          drops[i] += 0.6 + Math.random() * 0.4;
        }
      }, 33);

      // Sound — glitchy TV-static burst fading into a low drone
      try {
        const actx = new (window.AudioContext || (window as any).webkitAudioContext)();
        const dur = 5.5;

        // White noise burst
        const bufSize = Math.floor(actx.sampleRate * dur);
        const buf = actx.createBuffer(1, bufSize, actx.sampleRate);
        const data = buf.getChannelData(0);
        for (let i = 0; i < bufSize; i++) {
          data[i] = (Math.random() * 2 - 1) * Math.exp(-i / (actx.sampleRate * 1.2));
        }
        const noise = actx.createBufferSource();
        noise.buffer = buf;

        const noiseFilter = actx.createBiquadFilter();
        noiseFilter.type = 'bandpass';
        noiseFilter.frequency.value = 900;
        noiseFilter.Q.value = 0.4;

        const noiseGain = actx.createGain();
        noiseGain.gain.setValueAtTime(0.55, actx.currentTime);
        noiseGain.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + dur);

        noise.connect(noiseFilter);
        noiseFilter.connect(noiseGain);
        noiseGain.connect(actx.destination);
        noise.start();

        // Low drone underneath
        const osc = actx.createOscillator();
        osc.type = 'sawtooth';
        osc.frequency.setValueAtTime(55, actx.currentTime);
        osc.frequency.linearRampToValueAtTime(42, actx.currentTime + dur);

        const droneFilter = actx.createBiquadFilter();
        droneFilter.type = 'lowpass';
        droneFilter.frequency.value = 180;

        const droneGain = actx.createGain();
        droneGain.gain.setValueAtTime(0.18, actx.currentTime);
        droneGain.gain.exponentialRampToValueAtTime(0.001, actx.currentTime + dur);

        osc.connect(droneFilter);
        droneFilter.connect(droneGain);
        droneGain.connect(actx.destination);
        osc.start();
        osc.stop(actx.currentTime + dur);
      } catch(e) {}

      // Animate in
      requestAnimationFrame(() => overlay.classList.add('egg-overlay--visible'));

      // Auto-dismiss after 5.5s — no click-to-skip, user must see the whole thing
      const dismiss = () => {
        clearInterval(rainInterval);
        overlay.classList.remove('egg-overlay--visible');
        setTimeout(() => overlay.remove(), 400);
      };
      setTimeout(dismiss, 5500);
    }

    themeToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const newTheme = isDark ? 'light' : 'dark';
      playToggleSound(!isDark);
      document.documentElement.setAttribute('data-theme', newTheme);
      localStorage.setItem('theme', newTheme);

      toggleCount++;
      clearTimeout(toggleResetTimer);
      toggleResetTimer = setTimeout(() => { toggleCount = 0; }, 3000);
      if (toggleCount >= 7) {
        toggleCount = 0;
        showEasterEgg();
      }
    });
  </script>

  <!-- SCROLL ANIMATIONS -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('anim-in');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.anim-init').forEach(el => observer.observe(el));
  </script>

  <slot name="scripts" />

  <Analytics />

</body>
</html>
