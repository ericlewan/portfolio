---
import BaseLayout from './BaseLayout.astro';

interface NextProject {
  href: string;
  title: string;
}

interface Props {
  title: string;
  eyebrow: string;
  company: string;
  companyUrl?: string;
  role: string;
  timeline: string;
  intro: string;
  heroImage: string;
  heroImageAlt: string;
  heroBg: string;
  description: string;
  copyright?: boolean;
  nextProject?: NextProject;
}

const {
  title,
  eyebrow,
  company,
  companyUrl,
  role,
  timeline,
  intro,
  heroImage,
  heroImageAlt,
  heroBg,
  description,
  copyright = false,
  nextProject,
} = Astro.props;

const pageTitle = `${title.replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, '').trim()} — Yaroslav Kovalchuk`;
const canonical = `https://yaroslav.design${Astro.url.pathname}`;
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  activePage="work"
>
  <!-- HEADER -->
  <header class="cs-header">
    <div class="cs-header-inner">
      <div class="cs-header-top anim-in" style="--anim-delay: 0.05s">
        <a href="/" class="cs-back">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M11 7H3M3 7L6.5 3.5M3 7L6.5 10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Work
        </a>
        <div class="cs-header-actions">
          <span class="cs-view-count" id="view-count" aria-label="View count">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M3.275 15.296C2.425 14.192 2 13.639 2 12c0-1.64.425-2.191 1.275-3.296C4.972 6.374 7.818 4 12 4c4.182 0 7.028 2.374 8.725 4.704C21.575 9.81 22 10.361 22 12c0 1.64-.425 2.192-1.275 3.296C19.028 17.626 16.182 20 12 20c-4.182 0-7.028-2.374-8.725-4.704Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span class="cs-view-count-num"></span>
          </span>
          <button class="cs-share" id="share-btn" aria-label="Share">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8M16 6l-4-4-4 4M12 2v13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="cs-share-label">Share</span>
          </button>
        </div>
      </div>
      <p class="cs-eyebrow anim-in" style="--anim-delay: 0.13s">{eyebrow}</p>
      <h1 class="cs-title anim-in" style="--anim-delay: 0.21s" set:html={title} />
      <p class="cs-intro anim-in" style="--anim-delay: 0.29s">{intro}</p>
      <div class="cs-meta anim-in" style="--anim-delay: 0.37s">
        <div class="cs-meta-item">
          <p class="cs-meta-label">Role</p>
          <p class="cs-meta-value">{role}</p>
        </div>
        <div class="cs-meta-item">
          <p class="cs-meta-label">Timeline</p>
          <p class="cs-meta-value">{timeline}</p>
        </div>
        <div class="cs-meta-item">
          <p class="cs-meta-label">Company</p>
          <p class="cs-meta-value">
            {companyUrl ? (
              <a href={companyUrl} target="_blank" rel="noopener" class="cs-meta-link">{company} ↗</a>
            ) : (
              company
            )}
          </p>
        </div>
      </div>
    </div>
  </header>

  <script>
    // View count
    (async () => {
      const path = window.location.pathname.replace(/\/+$/, '') || '/';
      const sessionKey = `viewed:${path}`;
      const wrapper = document.getElementById('view-count');
      const numEl = wrapper?.querySelector('.cs-view-count-num');
      try {
        let views: number;
        if (sessionStorage.getItem(sessionKey)) {
          const res = await fetch(`/api/views?path=${encodeURIComponent(path)}`);
          views = (await res.json()).views;
        } else {
          const res = await fetch(`/api/views?path=${encodeURIComponent(path)}`, { method: 'POST' });
          views = (await res.json()).views;
          sessionStorage.setItem(sessionKey, '1');
        }
        if (wrapper && numEl && views > 0) {
          numEl.textContent = views.toLocaleString();
          wrapper.classList.add('loaded');
        }
      } catch {}
    })();

    // Share button
    const shareBtn = document.getElementById('share-btn');
    if (shareBtn) {
      shareBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const label = shareBtn.querySelector('.cs-share-label') as HTMLElement;
        try {
          if (navigator.share) {
            await navigator.share({ title: document.title, url });
          } else {
            await navigator.clipboard.writeText(url);
            if (label) {
              label.textContent = 'Copied!';
              setTimeout(() => { label.textContent = 'Share'; }, 2000);
            }
          }
        } catch {}
      });
    }
  </script>

  <!-- HERO IMAGE -->
  <div class={`cs-image-block cs-image-block--${heroBg} anim-in--scale`}>
    <div class="cs-image-block-inner">
      <img src={heroImage} alt={heroImageAlt} class="cs-img" />
    </div>
  </div>

  <!-- CONTENT -->
  <slot />

  <!-- COPYRIGHT -->
  {copyright && (
    <p style="text-align: center; padding: 20px var(--pad); font-family: 'Geist Mono', monospace; font-size: 10px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink); opacity: 0.25;">Work created for SupportYourApp, Inc. All rights reserved by SupportYourApp, Inc. Shared here for portfolio purposes.</p>
  )}

  <!-- NEXT PROJECT -->
  {nextProject ? (
    <div class="cs-next">
      <a href={nextProject.href} class="cs-next-inner">
        <p class="cs-next-label">Next project</p>
        <p class="cs-next-title">{nextProject.title} <span class="cs-next-arrow">→</span></p>
      </a>
    </div>
  ) : (
    <div class="cs-next">
      <a href="/" class="cs-next-inner">
        <p class="cs-next-label">Back to work</p>
        <p class="cs-next-title">See all projects <span class="cs-next-arrow">→</span></p>
      </a>
    </div>
  )}
</BaseLayout>
