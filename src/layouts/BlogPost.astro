---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  description: string;
}

const { title, date, description } = Astro.props;
const pageTitle = `${title.replace(/<[^>]+>/g, '')} — Yaroslav Kovalchuk`;
const canonical = `https://yaroslav.design${Astro.url.pathname}`;
const displayDate = new Date(date + 'T12:00:00Z').toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  activePage="writing"
>
  <!-- HEADER -->
  <header class="cs-header">
    <div class="cs-header-inner">
      <a href="/blog" class="cs-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M11 7H3M3 7L6.5 3.5M3 7L6.5 10.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Writing
      </a>
      <p class="cs-eyebrow">{displayDate}</p>
      <h1 class="cs-title" set:html={title} />
    </div>
  </header>

  <!-- POST BODY -->
  <div class="post-inner">
    <div class="post-body">
      <slot />
    </div>
  </div>
</BaseLayout>
