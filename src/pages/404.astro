---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Yaroslav Kovalchuk"
  description="This page doesn't exist."
  canonical="https://yaroslav.design/404"
>
  <div class="nf-wrap">

    <!-- Matrix rain lives here -->
    <canvas id="nf-canvas" aria-hidden="true"></canvas>

    <!-- Content layer (above canvas) -->
    <div class="nf-inner">

      <div class="nf-number" aria-hidden="true">
        <span class="nf-digit">4</span><span
          class="nf-digit nf-digit--accent"
          id="nf-zero">0</span><span class="nf-digit">4</span>
      </div>

      <div class="nf-content">
        <p class="nf-label">Page not found</p>
        <p class="nf-desc">You've reached the end of this particular internet.</p>
        <a href="/" class="nf-cta">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M13 8H3M3 8L7.5 3.5M3 8L7.5 12.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Go home
        </a>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .nf-wrap {
    position: relative;
    z-index: 1;           /* sits above canvas (z:0), below nav */
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100svh - 82px);
  }

  /* ── Matrix canvas — fixed full-viewport, behind everything ── */
  #nf-canvas {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Content ───────────────────────────────────── */
  .nf-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px var(--pad) 80px;
    width: 100%;
  }

  /* ── Giant number ──────────────────────────────── */
  .nf-number {
    display: flex;
    align-items: baseline;
    gap: 0;
    user-select: none;
    margin-bottom: 28px;
  }

  .nf-digit {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(120px, 24vw, 280px);
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    line-height: 1;
    letter-spacing: -0.02em;
    display: block;
  }

  .nf-digit--accent {
    color: var(--accent);
    cursor: pointer;
    will-change: transform;
    -webkit-tap-highlight-color: transparent;
    /* smooth scale on hover; JS disables this during glitch */
    transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nf-digit--accent:hover {
    transform: scale(1.07);
  }

  /* JS sets this class to skip transition during glitch frames */
  .nf-digit--accent.is-glitching {
    transition: none !important;
  }

  /* ── Copy ──────────────────────────────────────── */
  .nf-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .nf-label {
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.28;
    margin-bottom: 20px;
  }

  .nf-desc {
    font-family: 'Geist', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    opacity: 0.5;
    max-width: 520px;
    margin-bottom: 40px;
  }

  .nf-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: var(--ink);
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.18s;
  }

  .nf-cta:hover {
    background: var(--accent);
  }

  /* ── Responsive ────────────────────────────────── */
  @media (max-width: 600px) {
    .nf-digit {
      font-size: clamp(100px, 30vw, 140px);
    }
  }
</style>

<script>
  /* ═══════════════════════════════════════════════════════
     MATRIX RAIN — orange falling characters, mouse-reactive
  ═══════════════════════════════════════════════════════ */
  const canvas  = document.getElementById('nf-canvas') as HTMLCanvasElement;
  const ctx     = canvas.getContext('2d')!;
  const CHARS   = '404!?{}[]/|;:.01ERRORNOTFOUND';
  const FS      = 13; // font size / column width in px

  let cols = 0, drops: number[] = [], speeds: number[] = [];

  function initCols() {
    cols   = Math.floor(canvas.width / FS);
    drops  = Array.from({ length: cols }, () => -Math.floor(Math.random() * (canvas.height / FS)));
    speeds = Array.from({ length: cols }, () => 0.28 + Math.random() * 0.65);
  }

  function resize() {
    // Canvas is position:fixed so size it to the full viewport —
    // avoids ResizeObserver feedback loop from reading parent.offsetHeight
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    initCols();
  }
  resize();
  window.addEventListener('resize', resize);

  // Canvas is fixed at (0,0) so clientX/Y == canvas coords
  let mx = -9999, my = -9999;
  document.addEventListener('mousemove', (e: MouseEvent) => { mx = e.clientX; my = e.clientY; });
  document.addEventListener('mouseleave', () => { mx = -9999; my = -9999; });

  function drawFrame() {
    // Semi-transparent white blanket → creates the fading trail
    ctx.fillStyle = 'rgba(255,255,255,0.048)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.font = `${FS}px "Geist Mono",monospace`;
    ctx.textAlign = 'center';

    for (let i = 0; i < cols; i++) {
      const cx = i * FS + FS / 2;
      const cy = drops[i] * FS;

      // Proximity to cursor boosts brightness and speed
      const prox = Math.max(0, 1 - Math.hypot(cx - mx, cy - my) / 170);
      const alpha = (0.05 + prox * 0.6).toFixed(3);

      ctx.fillStyle = `rgba(255,85,0,${alpha})`;
      ctx.fillText(CHARS[Math.floor(Math.random() * CHARS.length)], cx, cy);

      // Reset column when it scrolls off-screen
      if (cy > canvas.height && Math.random() > 0.975) {
        drops[i] = -Math.floor(Math.random() * 22);
      }
      drops[i] += speeds[i] + prox * 0.45;
    }
  }

  setInterval(drawFrame, 33); // ~30 fps


  /* ═══════════════════════════════════════════════════════
     GLITCH — JS-driven, fires every ~1.5–3s automatically,
     rapid-fire on hover, intense burst on click
  ═══════════════════════════════════════════════════════ */
  const zero = document.getElementById('nf-zero')!;

  function runGlitch(intense = false): void {
    const totalSteps = intense ? 12 : 7;
    const stepMs     = intense ? 50 : 60;
    let   step = 0;

    zero.classList.add('is-glitching');

    const ticker = setInterval(() => {
      if (step++ >= totalSteps) {
        clearInterval(ticker);
        zero.classList.remove('is-glitching');
        zero.style.cssText = '';
        return;
      }
      if (step % 2 === 0) {
        const amp = intense ? 1 : 0.55;
        const tx  = ((Math.random() - 0.5) * 16 * amp).toFixed(1);
        const ty  = ((Math.random() - 0.5) *  7 * amp).toFixed(1);
        const sk  = ((Math.random() - 0.5) *  9 * amp).toFixed(1);
        const s1  = ((Math.random() - 0.5) * 14).toFixed(1);
        const s2  = ((Math.random() - 0.5) * 14).toFixed(1);
        zero.style.transform    = `translate(${tx}px,${ty}px) skewX(${sk}deg)`;
        zero.style.textShadow   = `${s1}px 0 0 rgba(0,200,255,.85),${s2}px 0 0 rgba(255,20,60,.85)`;
        zero.style.opacity      = (0.55 + Math.random() * 0.45).toFixed(2);
      } else {
        zero.style.transform  = '';
        zero.style.textShadow = '';
        zero.style.opacity    = '';
      }
    }, stepMs);
  }

  // Automatic random glitch every 1.2–2.8 s
  function scheduleAutoGlitch() {
    setTimeout(() => {
      runGlitch();
      scheduleAutoGlitch();
    }, 1200 + Math.random() * 1600);
  }
  scheduleAutoGlitch();

  // Hover → rapid continuous intense glitch
  let hoverTimer: number | null = null;
  zero.addEventListener('mouseenter', () => {
    hoverTimer = window.setInterval(() => runGlitch(true), 160);
  });
  zero.addEventListener('mouseleave', () => {
    if (hoverTimer !== null) { clearInterval(hoverTimer); hoverTimer = null; }
    zero.style.cssText = '';
    zero.classList.remove('is-glitching');
  });


  /* ═══════════════════════════════════════════════════════
     CLICK BURST — 30 orange chars explode from the "0"
  ═══════════════════════════════════════════════════════ */
  zero.addEventListener('click', () => {
    const { left, top, width, height } = zero.getBoundingClientRect();
    const ox = left + width  / 2;
    const oy = top  + height / 2;
    const COUNT = 30;

    for (let i = 0; i < COUNT; i++) {
      const el   = document.createElement('span');
      el.textContent = CHARS[Math.floor(Math.random() * CHARS.length)];
      const sz = 9 + Math.random() * 22;
      el.style.cssText = [
        'position:fixed',
        `left:${ox}px`,
        `top:${oy}px`,
        `font-family:'Geist Mono',monospace`,
        `font-size:${sz}px`,
        'color:#FF5500',
        'pointer-events:none',
        'z-index:9999',
        'transform:translate(-50%,-50%)',
        'opacity:1',
      ].join(';');
      document.body.appendChild(el);

      const angle = (i / COUNT) * Math.PI * 2 + (Math.random() - 0.5) * 0.5;
      const dist  = 70 + Math.random() * 190;
      const tx    = (Math.cos(angle) * dist).toFixed(1);
      const ty    = (Math.sin(angle) * dist).toFixed(1);
      const rot   = ((Math.random() - 0.5) * 480).toFixed(0);
      const dur   = 380 + Math.random() * 420;

      el.animate(
        [
          { transform: 'translate(-50%,-50%) scale(1.3) rotate(0deg)',                                  opacity: 1 },
          { transform: `translate(calc(-50% + ${tx}px),calc(-50% + ${ty}px)) scale(0.1) rotate(${rot}deg)`, opacity: 0 },
        ],
        { duration: dur, easing: 'cubic-bezier(0,.92,.44,1)', fill: 'forwards' }
      ).onfinish = () => el.remove();
    }
  });
</script>
