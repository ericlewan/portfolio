---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Yaroslav Kovalchuk"
  description="This page doesn't exist."
  canonical="https://yaroslav.design/404"
>
  <div class="nf-wrap">
    <div class="nf-inner">

      <!-- Dark frame — like the classified WIP card, but missing its content -->
      <div class="nf-frame">
        <p class="nf-frame-label">Error · 404</p>
        <span class="nf-num">404</span>
        <div class="nf-bars">
          <div class="nf-bar"></div>
          <div class="nf-bar nf-bar--mid"></div>
          <div class="nf-bar nf-bar--short"></div>
        </div>
      </div>

      <!-- Text -->
      <div class="nf-content">
        <h1 class="nf-heading">Page<br /><em>not found</em></h1>
        <p class="nf-desc">
          You followed a broken link or mistyped the address.
          The page you're after doesn't exist — or was never shipped.
        </p>
        <a href="/" class="nf-cta">← Go home</a>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .nf-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100svh - 82px);
    padding: 64px var(--pad);
  }

  .nf-inner {
    display: flex;
    align-items: center;
    gap: 72px;
    max-width: 960px;
    width: 100%;
  }

  /* ── Dark frame ─────────────────────────────── */
  .nf-frame {
    flex-shrink: 0;
    width: 360px;
    aspect-ratio: 3 / 4;
    background: #141825;
    border: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    position: relative;
    overflow: hidden;
  }

  /* Corner notches — like a design spec frame */
  .nf-frame::before,
  .nf-frame::after {
    content: '';
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: rgba(255, 255, 255, 0.15);
    border-style: solid;
  }
  .nf-frame::before {
    top: 12px;
    left: 12px;
    border-width: 1px 0 0 1px;
  }
  .nf-frame::after {
    bottom: 12px;
    right: 12px;
    border-width: 0 1px 1px 0;
  }

  .nf-frame-label {
    position: absolute;
    top: 18px;
    right: 18px;
    font-family: 'Geist Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.2);
  }

  /* Giant faded number — like a missing image placeholder */
  .nf-num {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(80px, 14vw, 120px);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.06);
    letter-spacing: 0.04em;
    line-height: 1;
    user-select: none;
  }

  /* Classified-style redacted bars */
  .nf-bars {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 140px;
  }

  .nf-bar {
    height: 8px;
    background: rgba(255, 255, 255, 0.09);
    border-radius: 2px;
    width: 100%;
  }
  .nf-bar--mid   { width: 72%; }
  .nf-bar--short { width: 50%; }

  /* ── Text side ──────────────────────────────── */
  .nf-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  .nf-heading {
    font-family: 'Crimson Pro', Georgia, serif;
    font-size: clamp(48px, 8vw, 72px);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: 0.01em;
    color: var(--ink);
    margin-bottom: 20px;
  }

  .nf-heading em {
    font-style: italic;
    font-family: 'Crimson Pro', Georgia, serif;
  }

  .nf-desc {
    font-family: 'Geist', sans-serif;
    font-size: 17px;
    line-height: 1.65;
    letter-spacing: 0.01em;
    color: var(--ink);
    opacity: 0.55;
    max-width: 380px;
    margin-bottom: 36px;
  }

  .nf-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-family: 'Geist Mono', monospace;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: var(--ink);
    border-radius: 100px;
    text-decoration: none;
    transition: background 0.18s;
  }

  .nf-cta:hover {
    background: var(--accent);
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 820px) {
    .nf-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 40px;
    }

    .nf-frame {
      width: 100%;
      max-width: 400px;
      aspect-ratio: 16 / 9;
    }

    .nf-content {
      align-items: center;
    }

    .nf-desc {
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
    .nf-wrap {
      padding: 40px var(--pad) 64px;
      align-items: flex-start;
    }

    .nf-heading {
      font-size: 44px;
    }
  }
</style>
