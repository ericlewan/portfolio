---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import CaseStudy from '../../layouts/CaseStudy.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import ImageBlock from '../../components/ImageBlock.astro';

export async function getStaticPaths() {
  const entries = await getCollection('case-studies');
  return entries.map(entry => ({
    params: { slug: entry.id.replace(/\.(mdx|md)$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, eyebrow, description, wip } = entry.data;

// Plain-text title for <title> tag
const plainTitle = title.replace(/<br\s*\/?>/gi, ' ').replace(/<[^>]+>/g, '').trim();
---

{wip ? (
  <BaseLayout
    title={`${plainTitle} — Yaroslav Kovalchuk`}
    description={description}
    activePage="work"
  >
    <div class="cs-wip">
      <a href="/" class="cs-back">← Work</a>
      <p class="cs-eyebrow">{eyebrow}</p>
      <h1 class="cs-title" set:html={title} />
      <p class="cs-wip-notice">In the works</p>
    </div>
  </BaseLayout>
) : (
  <CaseStudy {...entry.data}>
    <Content components={{ Section, ImageBlock }} />
  </CaseStudy>
)}
