---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('case-studies');
const wip = Object.fromEntries(
  caseStudies.map(e => [e.id.replace(/\.(mdx|md)$/, ''), e.data.wip ?? false])
);
---

<BaseLayout
  title="Yaroslav Kovalchuk — Product Designer"
  description="Product designer who built an AI product from scratch. Now designing conversion experiences for millions of users at Headway, the world's most downloaded book summary app."
  canonical="https://yaroslav.design/"
  activePage="work"
  isHome={true}
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Yaroslav Kovalchuk",
      "jobTitle": "Product Designer",
      "url": "https://yaroslav.design",
      "sameAs": [
        "https://linkedin.com/in/yaroslavdesign",
        "https://t.me/yaroself",
        "https://x.com/yaroslavdesign"
      ]
    }
    </script>
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-left">
      <div class="avatar">
        <img src="/Images/Other/profilePhotos_vTV8SaBVW9f1rhD235OrF0kesRl2_open-graph-cb02ff33-a046-429b-a13b-0e40e74f209c.webp" alt="Yaroslav Kovalchuk" />
      </div>
      <h1 class="hero-heading">
        Hey, Yaroslav here.<br />
        I craft things that <span class="word-ticker" id="wordTicker">convert</span>
      </h1>
      <p class="hero-desc">
        Built an AI product from scratch. Now I design for millions of users at the world's most downloaded book summary app.<br /><br />Currently somewhere between a hypothesis and a result.
      </p>
      <a href="mailto:hello@yaroslav.design" class="hero-cta">
        Get in touch
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3 8H13M13 8L8.5 3.5M13 8L8.5 12.5" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
    <div class="hero-right">
      <div class="avatar avatar--placeholder"></div>
      <table class="timeline">
        <tbody>
          <tr>
            <td class="timeline-year">2025</td>
            <td class="timeline-company"><a href="https://headway.inc" target="_blank" rel="noopener" class="timeline-link">Headway Inc</a></td>
            <td class="timeline-role">Product Designer, Growth</td>
          </tr>
          <tr>
            <td class="timeline-year">2023</td>
            <td class="timeline-company"><a href="https://quidget.ai" target="_blank" rel="noopener" class="timeline-link">Quidget</a></td>
            <td class="timeline-role">Founding Product Designer</td>
          </tr>
          <tr>
            <td class="timeline-year">2021</td>
            <td class="timeline-company"><a href="https://supportyourapp.com" target="_blank" rel="noopener" class="timeline-link">SupportYourApp</a></td>
            <td class="timeline-role">UX/UI Designer</td>
          </tr>
          <tr>
            <td class="timeline-year">2016</td>
            <td class="timeline-company">Freelance</td>
            <td class="timeline-role">All sorts of design work</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- WORK -->
  <section class="work" id="work">
    <div class="work-inner">
      <h2 class="section-title">Selected projects</h2>
      <div class="project-grid">

        <!-- Headway -->
        {wip['headway'] ? (
          <div class="card card--classified">
            <div class="card-image card-image--headway">
              <img src="/Images/Other/Headway/Screens.webp" alt="Headway app screens" class="card-img" />
            </div>
            <div class="card-meta">
              <p class="card-title">Growth design at 55+ million users</p>
              <p class="card-label">Headway &thinsp;·&thinsp; 2025 — Now</p>
            </div>
          </div>
        ) : (
          <a class="card" href="/cs/headway">
            <div class="card-image card-image--headway">
              <img src="/Images/Other/Headway/Screens.webp" alt="Headway app screens" class="card-img" />
            </div>
            <div class="card-meta">
              <p class="card-title">Growth design at 55+ million users</p>
              <p class="card-label">Headway &thinsp;·&thinsp; 2025 — Now</p>
            </div>
          </a>
        )}

        <!-- Quidget AI Agent -->
        <a class="card" href="/cs/quidget-ai-agent">
          <div class="card-image card-image--light">
            <img src="/Images/AI Agent at Quidget/b908c25d-19e5-4164-a98c-e2beb0c42983.webp" alt="Quidget AI Agent onboarding" class="card-img" />
          </div>
          <div class="card-meta">
            <p class="card-title">AI Agent onboarding in 4 steps</p>
            <p class="card-label">Quidget &thinsp;·&thinsp; 2024</p>
          </div>
        </a>

        <!-- Quidget App -->
        <a class="card" href="/cs/quidget-app">
          <div class="card-image card-image--light">
            <img src="/Images/Application UI & UX at Quidget/12b3146c-3230-49f4-9248-e0ef0e878bff.webp" alt="Quidget Application UI" class="card-img" />
          </div>
          <div class="card-meta">
            <p class="card-title">Designing a product from zero to launch</p>
            <p class="card-label">Quidget &thinsp;·&thinsp; 2023–2025</p>
          </div>
        </a>

        <!-- Remoter.me -->
        <a class="card" href="/cs/remoter">
          <div class="card-image card-image--dark-green">
            <img src="/Images/Website at Remoter.me/93cc111a-a10f-43e4-92d1-501ee5e0f5c6.webp" alt="Remoter.me landing page" class="card-img" />
          </div>
          <div class="card-meta">
            <p class="card-title">Website design built to scale</p>
            <p class="card-label">Remoter.me &thinsp;·&thinsp; 2023</p>
          </div>
        </a>

      </div>
    </div>
  </section>

  <script slot="scripts">
    // Card expand cursor logic
    const cursorEl = document.getElementById('cursor');
    const cursorLabel = cursorEl?.querySelector('.cursor-label');
    document.querySelectorAll('.card').forEach(card => {
      card.addEventListener('mouseenter', () => {
        const isClassified = card.classList.contains('card--classified');
        cursorEl?.classList.add('cursor--expanded');
        if (isClassified) cursorEl?.classList.add('cursor--wip');
        if (cursorLabel) cursorLabel.textContent = isClassified ? 'Case study in progress' : 'View case study';
      });
      card.addEventListener('mouseleave', () => {
        cursorEl?.classList.remove('cursor--expanded', 'cursor--type-external', 'cursor--wip');
        if (cursorLabel) cursorLabel.textContent = 'View case study';
      });
    });

    // Word ticker animation
    (function () {
      const words = ['convert', 'engage', 'delight', 'matter'];
      const el = document.getElementById('wordTicker');
      if (!el) return;
      let i = 0;
      function next() {
        i++;
        if (i >= words.length) return;
        const isFinal = i === words.length - 1;
        el.style.transition = 'transform 0.55s ease-in, opacity 0.55s ease-in';
        el.style.transform = 'translateY(-0.35em)';
        el.style.opacity = '0';
        setTimeout(function () {
          el.style.transition = 'none';
          el.style.transform = 'translateY(0.4em)';
          el.style.opacity = '0';
          el.textContent = words[i];
          void el.offsetWidth;
          el.style.transition = 'transform 0.55s ease-out, opacity 0.55s ease-out';
          el.style.transform = 'translateY(0)';
          el.style.opacity = '1';
          if (!isFinal) setTimeout(next, 1800);
        }, 550);
      }
      setTimeout(next, 1800);
    })();
  </script>
</BaseLayout>
